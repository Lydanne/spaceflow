# 基础配置
NUXT_PUBLIC_APP_NAME=Teax
NUXT_PUBLIC_APP_URL=http://localhost:3000


# 数据库
NUXT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teax
NUXT_POSTGRES_DB=teax
NUXT_POSTGRES_USER=postgres
NUXT_POSTGRES_PASSWORD=postgres
NUXT_POSTGRES_HOST=localhost
NUXT_POSTGRES_PORT=5432

# Redis
NUXT_REDIS_URL=redis://localhost:6379
NUXT_REDIS_HOST=localhost
NUXT_REDIS_PORT=6379
NUXT_REDIS_PASSWORD=

# Gitea OAuth
NUXT_GITEA_URL=https://git.example.com
NUXT_GITEA_CLIENT_ID=xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NUXT_GITEA_CLIENT_SECRET=your_gitea_client_secret
NUXT_GITEA_SERVICE_TOKEN=your_gitea_service_token
NUXT_GITEA_WEBHOOK_SECRET=your_gitea_webhook_secret

# 飞书
NUXT_FEISHU_APP_ID=cli_xxxxxxxx
NUXT_FEISHU_APP_SECRET=your_feishu_app_secret

# Session
NUXT_SESSION_PASSWORD=at-least-32-characters-long-secret-key!!
NUXT_TOKEN_ENCRYPT_SECRET=xxxxxxxxxxxxxxxxxx

# 日志级别默认值（0=静默, 1=标准, 2=调试）
NUXT_VERBOSE_DEFAULT=1

# Agents 元数据仓库（手动接入）
NUXT_AGENT_META_REPO_URL=
NUXT_AGENT_META_REPO_BRANCH=main
NUXT_AGENT_META_REPO_AUTH_TYPE=token
NUXT_AGENT_META_REPO_TOKEN=
NUXT_AGENT_BOT_USERNAME=TeaxBot
NUXT_AGENT_BOT_EMAIL=teaxbot@local
NUXT_AGENT_BOT_TOKEN=

# Agent Runtime（P1）
NUXT_AGENT_RUNTIME_ROOT=./.runtime
NUXT_AGENT_RUNTIME_DOCKER_BIN=docker
NUXT_AGENT_RUNTIME_DOCKER_BASE_DOCKERFILE=docker/base/node24-vscode-browser.Dockerfile
NUXT_AGENT_RUNTIME_DOCKER_BASE_BUILD_CONTEXT=.
NUXT_AGENT_RUNTIME_DOCKER_BUILD_ON_START=true
NUXT_AGENT_RUNTIME_DOCKER_WORKSPACE_ROOT=/runtime
NUXT_AGENT_RUNTIME_KEEP_WORKTREE_ON_STOP=false
NUXT_AGENT_RUNTIME_OPENCODE_START_COMMAND=
